        <hashTree/>

        <!-- /latency?ms=200 -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /latency?ms=200" enabled="true">
          <stringProp name="HTTPSampler.domain">9.223.206.255</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
